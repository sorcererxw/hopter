{
  "name": "orchd",
  "version": "0.1.0",
  "private": true,
  "license": "Apache-2.0",
  "type": "module",
  "scripts": {
    "dev": "bun --watch src/server/bootstrap/index.ts",
    "dev:lan": "ORCHD_HOST=0.0.0.0 bun --watch src/server/bootstrap/index.ts",
    "start": "bun src/server/bootstrap/index.ts",
    "start:lan": "ORCHD_HOST=0.0.0.0 bun src/server/bootstrap/index.ts",
    "ui:add": "bunx --bun shadcn@latest add",
    "build:web:css": "bunx --bun @tailwindcss/cli -i ./src/web/app/styles/index.css -o ./web-dist/app.css",
    "build:web": "bun src/web/app/build.ts",
    "build": "bun run build:web",
    "test": "bun test",
    "validate:docs": "bun scripts/validate-docs.ts",
    "validate:m0": "bun scripts/validate-m0.ts",
    "validate:m1": "bun scripts/validate-m1.ts",
    "validate:m2": "bun scripts/validate-m2.ts",
    "validate:m3": "bun scripts/validate-m3.ts",
    "validate:m4": "bun scripts/validate-m4.ts",
    "validate:m5": "bun scripts/validate-m5.ts",
    "validate:template-snake": "bun scripts/validate-template-snake.ts"
  },
  "dependencies": {
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-slot": "^1.2.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cookie": "^1.0.2",
    "hono": "^4.9.2",
    "lucide-react": "^0.542.0",
    "playwright": "^1.59.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.9.4",
    "tailwind-merge": "^3.3.1"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.1.11",
    "tailwindcss": "^4.1.11",
    "tw-animate-css": "^1.4.0"
  }
}
