
{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "hopter-site",
  "main": "./dist/_worker.js/index.js",
  "assets": {
    "directory": "./dist"
  },
  "compatibility_date": "2026-04-19",
  "routes": [
    {
      "pattern": "hopter.dev",
      "custom_domain": true
    }
  ]
}
